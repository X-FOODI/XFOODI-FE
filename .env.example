# API Configuration
INTERNAL_ADMIN_API_URL=https://admin.restx.food/api
INTERNAL_API_URL=https://demo.restx.food/api

# Next.js Configuration
NEXT_PUBLIC_API_URL=https://demo.restx.food/api
NEXT_PUBLIC_ADMIN_API_URL=https://admin.restx.food/api

# Google Gemini AI
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google Sign-In (OAuth 2.0 Web client ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: override Google auth path (default /auth/google → full URL = NEXT_PUBLIC_API_URL + path)
# NEXT_PUBLIC_AUTH_GOOGLE_LOGIN_PATH=/auth/google

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:5000/api

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Base Domain Configuration
NEXT_PUBLIC_BASE_DOMAIN=xfoodi.website
